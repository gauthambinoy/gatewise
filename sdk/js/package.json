{
  "name": "@gatewise/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript client for the GateWise AI governance gateway (OpenAI-compatible).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "gatewise",
    "llm",
    "gateway",
    "openai",
    "governance",
    "ai",
    "compliance"
  ],
  "homepage": "https://github.com/gauthambinoy/gatewise",
  "repository": {
    "type": "git",
    "url": "https://github.com/gauthambinoy/gatewise.git",
    "directory": "sdk/js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
