# Caddy reverse proxy for the Auvex single-box deploy. It terminates TLS for the
# nip.io host (auto-provisioning a Let's Encrypt cert) and forwards to the
# console container, whose nginx serves the SPA and already proxies /v1 and /auth
# to the gateway — so the browser sees one origin and there's no CORS to manage.
#
# AUVEX_DOMAIN is injected from the host .env, so the same file works on any IP.
# Add a global `{ email you@example.com }` block if you want renewal-failure
# notices; it's optional — auto-HTTPS works without an account email.

{$AUVEX_DOMAIN} {
	encode zstd gzip

	reverse_proxy console:80

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
