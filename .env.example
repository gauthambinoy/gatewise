# --- OpenRouter (AI calls) ---
# OpenAI-compatible endpoint; swap the model string to change providers.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_API_KEY=

# --- Database ---
# These feed both the Postgres container and (from Phase 1) the gateway's
# datasource. The password here is a LOCAL DEV default only — never a real secret.
POSTGRES_DB=auvex
POSTGRES_USER=auvex
POSTGRES_PASSWORD=auvex
POSTGRES_PORT=5432
POSTGRES_URL=jdbc:postgresql://localhost:5432/auvex

# --- Cache ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Amazon Bedrock (optional native provider) ---
# Enable to route bedrock/* models (e.g. bedrock/anthropic.claude-3-5-sonnet-20240620-v1:0)
# through AWS Bedrock, signed with SigV4. Leave disabled if you don't use Bedrock.
AUVEX_BEDROCK_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only for temporary STS credentials; leave blank otherwise.
AWS_SESSION_TOKEN=

# --- Console SSO (optional, real OIDC sign-in) ---
# Fill in to enable "Sign in with Google" on the console. redirect-uri must be registered with
# Google and point at https://<your-gateway>/auth/oidc/google/callback. tenant-slug is the tenant
# users sign into; auto-provision creates a member on first login with default-role.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_TENANT_SLUG=
GOOGLE_AUTO_PROVISION=false
# Okta (or any OIDC): set issuer + the three endpoints + client id/secret + redirect + tenant.
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_AUTHORIZATION_URI=
OKTA_TOKEN_URI=
OKTA_JWKS_URI=
OKTA_REDIRECT_URI=
OKTA_TENANT_SLUG=

# --- Console SAML 2.0 SSO (optional) ---
# SP-initiated SAML. Create a SAML app in the IdP, set its ACS to
# https://<your-gateway>/auth/saml/okta/acs and audience to SAML_OKTA_SP_ENTITY_ID, then paste the
# IdP's signing certificate (PEM, the BEGIN/END CERTIFICATE block) into SAML_OKTA_CERT.
SAML_OKTA_ENTITY_ID=
SAML_OKTA_SSO_URL=
SAML_OKTA_CERT=
SAML_OKTA_SP_ENTITY_ID=
SAML_OKTA_ACS_URL=
SAML_OKTA_TENANT_SLUG=
SAML_OKTA_AUTO_PROVISION=false

# --- SCIM 2.0 provisioning (optional) ---
# A long-lived bearer token the IdP presents on every /scim/v2 call (separate from API keys), plus
# the tenant SCIM provisions members into. SCIM is off until SCIM_TOKEN is set.
SCIM_TOKEN=
SCIM_TENANT_SLUG=

# --- App ---
SERVER_PORT=8080
