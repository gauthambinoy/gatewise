# --- OpenRouter (AI calls) ---
# OpenAI-compatible endpoint; swap the model string to change providers.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_API_KEY=

# --- Database ---
POSTGRES_URL=jdbc:postgresql://localhost:5432/auvex
POSTGRES_USER=auvex
POSTGRES_PASSWORD=

# --- Cache ---
REDIS_URL=redis://localhost:6379

# --- App ---
SERVER_PORT=8080
