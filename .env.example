# --- OpenRouter (AI calls) ---
# OpenAI-compatible endpoint; swap the model string to change providers.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_API_KEY=

# --- Database ---
# These feed both the Postgres container and (from Phase 1) the gateway's
# datasource. The password here is a LOCAL DEV default only — never a real secret.
POSTGRES_DB=auvex
POSTGRES_USER=auvex
POSTGRES_PASSWORD=auvex
POSTGRES_PORT=5432
POSTGRES_URL=jdbc:postgresql://localhost:5432/auvex

# --- Cache ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- App ---
SERVER_PORT=8080
